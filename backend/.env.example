MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/folderupload?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
PORT=5000
FRONTEND_URL=http://localhost:3000
DNS_SERVERS=8.8.8.8,1.1.1.1

# Cloudinary (required for image uploads)
# Get these from: https://console.cloudinary.com → Dashboard → API Keys
# CLOUDINARY_CLOUD_NAME is the short cloud name (example: dxy1a2b3c) — NOT your app name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional single-line alternative:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

NODE_ENV=development
